# ==============================
# Lab 2 — Environment Variables
# ==============================

# ----------------------------------
# EDGE AUTHENTICATION (REQUIRED)
# ----------------------------------
# This API key is checked by NGINX before requests reach the API.
# Replace the value below with a long, random string.
# Generate one using:
#   openssl rand -hex 32
#
# Example:
# EDGE_API_KEY=a3f92d1e8b7c6f4d9a2e1c3b5f6a7d8c9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4

EDGE_API_KEY=replace-with-long-random-value


# ----------------------------------
# OLLAMA MODEL CONFIGURATION
# ----------------------------------
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://ollama:11434


# ----------------------------------
# WEAVIATE CONNECTION SETTINGS
# ----------------------------------
WEAVIATE_SCHEME=http
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080


# ----------------------------------
# OPTIONAL RAG TUNING SETTINGS
# ----------------------------------
RAG_TOP_K=5
RAG_MAX_SOURCE_CHARS=1200

GRADIO_HTTP_TIMEOUT_S=600


# ------------------------------------------
# SECURITY MEMORY SETTINGS (separate class)
# ------------------------------------------
# Weaviate uses "classes" instead of Qdrant "collections".
# The security corpus lives in its own class, separate from LabDoc.

SECURITY_CLASS=ExpandedVSCodeMemory
SECURITY_TOP_K=6
SECURITY_CHUNK_CHARS=1200
SECURITY_CHUNK_OVERLAP=200

# Security memory embeddings via Ollama
# Pull with: docker exec -it ollama ollama pull nomic-embed-text
SECURITY_EMBED_MODEL=nomic-embed-text
SECURITY_EMBED_DIM=768
